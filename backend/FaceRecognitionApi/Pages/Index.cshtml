@page
@model FaceRecognitionApi.Pages.IndexModel
@{
    ViewData["Title"] = "Recognition Results";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">📋 Recognition Results</h3>
    <span class="badge bg-secondary fs-6" id="totalBadge">@Model.Logs.Count records</span>
</div>

<p class="text-muted small mb-4">
    Results appear here automatically whenever the mobile or desktop app sends a photo.
    The page refreshes every 5 seconds.
</p>

<div id="resultsContainer">
    @await Html.PartialAsync("_ResultsTable", Model.Logs)
</div>

@section Scripts {
<script>
(function () {
    let lastId = @(Model.Logs.FirstOrDefault()?.Id ?? 0);

    async function refresh() {
        try {
            const resp = await fetch('/api/recognitions?limit=20');
            if (!resp.ok) return;
            const logs = await resp.json();
            if (logs.length === 0) return;
            if (logs[0].id === lastId) return;   // nothing new

            lastId = logs[0].id;
            document.getElementById('totalBadge').textContent = logs.length + ' records';

            const tbody = document.querySelector('#resultsContainer tbody');
            if (!tbody) { location.reload(); return; }

            tbody.innerHTML = logs.map(l => {
                const dt = new Date(l.recognizedAt + 'Z').toLocaleString();
                const badge = l.found
                    ? `<span class="badge bg-success">✅ Found</span>`
                    : `<span class="badge bg-warning text-dark">❌ Not found</span>`;
                const conf = l.found ? `${(l.confidence * 100).toFixed(1)}%` : '—';
                return `<tr>
                    <td class="text-muted small">${dt}</td>
                    <td>${badge}</td>
                    <td class="fw-semibold">${l.personName || '—'}</td>
                    <td>${conf}</td>
                    <td class="text-muted small">${l.message}</td>
                </tr>`;
            }).join('');
        } catch (e) { /* ignore network errors during polling */ }
    }

    setInterval(refresh, 5000);
})();
</script>
}
