@page
@model FaceRecognitionApi.Pages.Persons.IndexModel
@{
    ViewData["Title"] = "Person Database";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">👥 Person Database</h3>
    <span class="badge bg-secondary fs-6">@Model.Total records</span>
</div>


<div class="card mb-4 border-primary">
    <div class="card-header bg-primary text-white fw-semibold">
        📂 Załaduj bazę danych z pliku CSV
    </div>
    <div class="card-body">
        <p class="card-text text-muted small mb-2">
            Podaj pełną ścieżkę do pliku CSV na serwerze (np.
            <code>C:\Users\Ty\faces.csv</code> lub
            <code>/home/user/faces.csv</code>).
            Format CSV: kolumny <code>id</code> i <code>label</code>
            (np. <code>1,Robert Downey Jr_87.jpg</code>).
        </p>
        <form method="post" asp-page-handler="Seed">
            @Html.AntiForgeryToken()
            <div class="input-group">
                <input type="text" class="form-control" name="CsvFilePath"
                       value="@Model.CsvFilePath"
                       placeholder="C:\ścieżka\do\faces.csv" />
                <button type="submit" class="btn btn-primary">Załaduj</button>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(Model.SeedMessage))
        {
            <div class="alert @(Model.SeedSuccess ? "alert-success" : "alert-warning") mt-2 mb-0 py-2">
                @Model.SeedMessage
            </div>
        }
    </div>
</div>
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" class="form-control" name="search" value="@Model.Search"
               placeholder="Search by name…" />
        <button type="submit" class="btn btn-dark">Search</button>
        @if (!string.IsNullOrEmpty(Model.Search))
        {
            <a asp-page="/Persons/Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (Model.Persons.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:80px">#</th>
                    <th>Name</th>
                    <th>Image file</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Persons)
                {
                    <tr>
                        <td class="text-muted">@p.Id</td>
                        <td class="fw-semibold">@p.Name</td>
                        <td class="text-muted small">@p.ImageFileName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-page="/Persons/Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-search="@Model.Search">‹ Previous</a>
                </li>
                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-page="/Persons/Index"
                           asp-route-page="@i"
                           asp-route-search="@Model.Search">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-page="/Persons/Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-search="@Model.Search">Next ›</a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="alert alert-info">
        @if (string.IsNullOrEmpty(Model.Search))
        {
            <span>Baza danych jest pusta. Użyj formularza powyżej, żeby załadować dane z pliku CSV.</span>
        }
        else
        {
            <span>No persons found matching "<strong>@Model.Search</strong>".</span>
        }
    </div>
}
