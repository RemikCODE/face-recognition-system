<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="24,20" Spacing="16">

        <Label Text="API Settings"
               FontSize="20"
               FontAttributes="Bold" />

        <BoxView HeightRequest="1" Color="LightGray" />

        <Label Text="Backend URL"
               FontAttributes="Bold" />
        <Entry x:Name="ApiUrlEntry"
               Placeholder="http://192.168.1.x:5233"
               Keyboard="Url"
               ReturnType="Done"
               ReturnCommand="{Binding SaveCommand}" />

        <Label Text="• Android emulator: use 10.0.2.2 instead of localhost"
               FontSize="12"
               TextColor="Gray" />
        <Label Text="• Real device: enter your PC's local network IP address"
               FontSize="12"
               TextColor="Gray" />
        <Label Text="• Windows desktop: http://localhost:5233"
               FontSize="12"
               TextColor="Gray" />

        <Button Text="Save"
                Clicked="OnSaveClicked"
                BackgroundColor="#333333"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="48" />

        <Label x:Name="StatusLabel"
               HorizontalTextAlignment="Center"
               IsVisible="False" />

    </VerticalStackLayout>
</ContentPage>
