<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="24,20" Spacing="16">

        <Label Text="API Settings"
               FontSize="20"
               FontAttributes="Bold" />

        <BoxView HeightRequest="1" Color="LightGray" />

        <Label Text="Backend URL"
               FontAttributes="Bold" />
        <Entry x:Name="ApiUrlEntry"
               Placeholder="http://192.168.1.x:5233"
               Keyboard="Url"
               ReturnType="Done"
               ReturnCommand="{Binding SaveCommand}" />

        <Label Text="• Enter only scheme + host + port – no path (e.g. http://localhost:5233)"
               FontSize="12"
               TextColor="Gray" />
        <Label Text="• ❌ Wrong: http://localhost:5001/recognize  (that is the Python ML service, not the backend)"
               FontSize="12"
               TextColor="Gray" />
        <Label Text="• ✅ Windows desktop: http://localhost:5233"
               FontSize="12"
               TextColor="Gray" />
        <Label Text="• ✅ Android emulator: http://10.0.2.2:5233"
               FontSize="12"
               TextColor="Gray" />
        <Label Text="• ✅ Real device: http://&lt;your-PC-LAN-IP&gt;:5233"
               FontSize="12"
               TextColor="Gray" />

        <Button Text="Save"
                Clicked="OnSaveClicked"
                BackgroundColor="#333333"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="48" />

        <Label x:Name="StatusLabel"
               HorizontalTextAlignment="Center"
               IsVisible="False" />

    </VerticalStackLayout>
</ContentPage>
