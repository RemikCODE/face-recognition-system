<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.HistoryPage"
             Title="History"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              BackgroundColor="#1565C0"
              Padding="20,24,16,20">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="Recognition History"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="Results fetched from the backend"
                       FontSize="13"
                       TextColor="#BBDEFB" />
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    x:Name="RefreshButton"
                    Text="↻"
                    FontSize="20"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    Clicked="OnRefreshClicked"
                    VerticalOptions="Center"
                    WidthRequest="44"
                    HeightRequest="44" />
        </Grid>

        <!-- ── Content ── -->
        <Grid Grid.Row="1">

            <!-- Loading overlay -->
            <VerticalStackLayout x:Name="LoadingPanel"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsRunning="True"
                                   Color="#1565C0"
                                   HorizontalOptions="Center" />
                <Label Text="Loading…"
                       FontSize="14"
                       TextColor="#9E9E9E"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Error panel -->
            <VerticalStackLayout x:Name="ErrorPanel"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Padding="32"
                                 Spacing="12">
                <Label Text="⚠️"
                       FontSize="48"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="ErrorLabel"
                       FontSize="14"
                       TextColor="#9E9E9E"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Results list -->
            <RefreshView x:Name="RefreshView"
                         Refreshing="OnPullRefreshing">
                <CollectionView x:Name="ResultsList"
                                Margin="16,12,16,16">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    StrokeShape="RoundRectangle 14"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    BackgroundColor="White"
                                    Padding="16,14">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      RowSpacing="5"
                                      ColumnSpacing="10">

                                    <!-- Name -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#212121"
                                           VerticalOptions="Center" />

                                    <!-- Status badge -->
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Status}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{Binding StatusColor}"
                                           VerticalOptions="Center" />

                                    <!-- Time -->
                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding TimeText}"
                                           FontSize="12"
                                           TextColor="#9E9E9E" />

                                    <!-- Confidence -->
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Confidence}"
                                           FontSize="12"
                                           TextColor="#757575" />

                                    <!-- Message -->
                                    <Label Grid.Row="2" Grid.ColumnSpan="2"
                                           Text="{Binding Message}"
                                           FontSize="12"
                                           TextColor="#BDBDBD"
                                           LineBreakMode="TailTruncation" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="12"
                                             Margin="0,60,0,0">
                            <Label Text="📋"
                                   FontSize="52"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="No recognition history yet"
                                   FontSize="16"
                                   TextColor="#9E9E9E"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Recognize a face to see results here"
                                   FontSize="13"
                                   TextColor="#BDBDBD"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                </CollectionView>
            </RefreshView>

        </Grid>

    </Grid>

</ContentPage>
