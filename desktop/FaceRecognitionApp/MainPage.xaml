<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.MainPage"
             Title="Recognize"
             BackgroundColor="{DynamicResource PageBg}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{StaticResource Surface}"
                             Padding="20,28,20,20"
                             Spacing="4">
            <Label Text="Face Recognition System"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="0.3" />
            <Label x:Name="InstructionLabel"
                   FontSize="13"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
            <!-- subtle bottom separator -->
            <BoxView HeightRequest="1"
                     Color="{StaticResource BorderColor}"
                     Margin="0,12,0,0" />
        </VerticalStackLayout>

        <!-- ── Scrollable content ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Photo preview card -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="260">
                    <Grid>
                        <!-- Placeholder when no photo selected -->
                        <VerticalStackLayout x:Name="PhotoPlaceholder"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="10">
                            <!-- Simple geometric placeholder instead of emoji -->
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource BorderColor}"
                                    StrokeThickness="1.5"
                                    BackgroundColor="{StaticResource SurfaceElev}"
                                    WidthRequest="72"
                                    HeightRequest="60"
                                    HorizontalOptions="Center" />
                            <Label Text="No image selected"
                                   TextColor="{StaticResource TextMuted}"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <!-- Selected photo -->
                        <Image x:Name="PhotoPreview"
                               Aspect="AspectFit"
                               IsVisible="False" />
                    </Grid>
                </Border>

                <!-- Result card (shown after recognition) -->
                <Border x:Name="ResultCard"
                        IsVisible="False"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20,16">
                    <VerticalStackLayout Spacing="14">

                        <Label x:Name="ResultStatusLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               CharacterSpacing="0.2" />

                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="PERSON"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}"
                                       CharacterSpacing="1.5" />
                                <Label x:Name="ResultNameLabel"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="CONFIDENCE"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}"
                                       CharacterSpacing="1.5" />
                                <Label x:Name="ResultConfidenceLabel"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label x:Name="ResultMessageLabel"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Bottom action bar ── -->
        <VerticalStackLayout Grid.Row="2"
                             BackgroundColor="{StaticResource Surface}"
                             Padding="16,14,16,22"
                             Spacing="10">

            <!-- Top separator -->
            <BoxView HeightRequest="1"
                     Color="{StaticResource BorderColor}"
                     Margin="-16,-14,-16,0" />

            <!-- Loading state -->
            <VerticalStackLayout x:Name="LoadingPanel"
                                 IsVisible="False"
                                 HorizontalOptions="Center"
                                 Spacing="8">
                <ActivityIndicator IsRunning="True"
                                   Color="{StaticResource Accent}"
                                   HorizontalOptions="Center" />
                <Label Text="Analyzing image..."
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Photo source buttons -->
            <VerticalStackLayout x:Name="PhotoButtonsRow" Spacing="10">
                <!-- Desktop: file picker -->
                <Button x:Name="SelectFileButton"
                        Text="Select File"
                        Clicked="OnSelectFileClicked"
                        BackgroundColor="{StaticResource SurfaceElev}"
                        TextColor="{StaticResource TextPrimary}"
                        BorderColor="{StaticResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />
                <!-- Mobile: camera -->
                <Button x:Name="TakePhotoButton"
                        Text="Take Photo"
                        Clicked="OnTakePhotoClicked"
                        BackgroundColor="{StaticResource SurfaceElev}"
                        TextColor="{StaticResource TextPrimary}"
                        BorderColor="{StaticResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />
            </VerticalStackLayout>

            <!-- Primary action button -->
            <Button x:Name="RecognizeButton"
                    Text="Identify Face"
                    Clicked="OnRecognizeClicked"
                    IsEnabled="False"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="{StaticResource TextPrimary}"
                    CornerRadius="8"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="50" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>
