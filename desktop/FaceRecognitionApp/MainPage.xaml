<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.MainPage"
             Title="Face Recognition">

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16">

            <!-- Title -->
            <Label Text="🔍 Face Recognition"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <!-- Platform-specific instruction -->
            <Label x:Name="InstructionLabel"
                   FontSize="13"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center" />

            <!-- Photo preview -->
            <Frame BorderColor="LightGray"
                   CornerRadius="12"
                   Padding="0"
                   HeightRequest="240"
                   IsClippedToBounds="True"
                   HorizontalOptions="Fill">
                <Image x:Name="PhotoPreview"
                       Aspect="AspectFill"
                       BackgroundColor="#eeeeee" />
            </Frame>

            <!-- Desktop: select file from disk -->
            <Button x:Name="SelectFileButton"
                    Text="📁 Select File"
                    Clicked="OnSelectFileClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="44"
                    IsVisible="False"
                    HorizontalOptions="Center" />

            <!-- Mobile: take photo with camera -->
            <Button x:Name="TakePhotoButton"
                    Text="📷 Take Photo"
                    Clicked="OnTakePhotoClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="44"
                    IsVisible="False"
                    HorizontalOptions="Center" />

            <!-- Recognize button -->
            <Button x:Name="RecognizeButton"
                    Text="Recognize Face"
                    Clicked="OnRecognizeClicked"
                    IsEnabled="False"
                    BackgroundColor="#1a73e8"
                    TextColor="White"
                    CornerRadius="8"
                    FontSize="16"
                    HeightRequest="52" />

            <!-- Loading indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#1a73e8"
                               HorizontalOptions="Center" />

            <!-- Result card -->
            <Frame x:Name="ResultCard"
                   IsVisible="False"
                   BorderColor="LightGray"
                   CornerRadius="12"
                   Padding="16"
                   BackgroundColor="White">
                <VerticalStackLayout Spacing="10">

                    <Label x:Name="ResultTitleLabel"
                           FontSize="17"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />

                    <BoxView HeightRequest="1" Color="LightGray" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="8"
                          ColumnSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Name:" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="ResultNameLabel" Grid.Row="0" Grid.Column="1" FontSize="16" VerticalOptions="Center" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Confidence:" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="ResultConfidenceLabel" Grid.Row="1" Grid.Column="1" VerticalOptions="Center" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Message:" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="ResultMessageLabel" Grid.Row="2" Grid.Column="1" TextColor="Gray" FontSize="13" VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
