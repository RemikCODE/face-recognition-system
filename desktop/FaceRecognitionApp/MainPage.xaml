<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.MainPage"
             Title="Recognize"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="#1565C0"
                             Padding="20,24,20,20"
                             Spacing="4">
            <Label Text="Face Recognition"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label x:Name="InstructionLabel"
                   FontSize="13"
                   TextColor="#BBDEFB"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- ── Scrollable content ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Photo preview -->
                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        HeightRequest="260">
                    <Grid>
                        <!-- Placeholder when no photo is selected -->
                        <VerticalStackLayout x:Name="PhotoPlaceholder"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="8">
                            <Label Text="🖼️"
                                   FontSize="52"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="No photo selected"
                                   TextColor="#BDBDBD"
                                   FontSize="14"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <!-- Photo -->
                        <Image x:Name="PhotoPreview"
                               Aspect="AspectFit"
                               IsVisible="False" />
                    </Grid>
                </Border>

                <!-- Result card (shown after recognition) -->
                <Border x:Name="ResultCard"
                        IsVisible="False"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="20,16">
                    <VerticalStackLayout Spacing="12">

                        <Label x:Name="ResultStatusLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />

                        <BoxView HeightRequest="1" Color="#EEEEEE" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="PERSON"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#9E9E9E"
                                       CharacterSpacing="1" />
                                <Label x:Name="ResultNameLabel"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#212121" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="CONFIDENCE"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#9E9E9E"
                                       CharacterSpacing="1" />
                                <Label x:Name="ResultConfidenceLabel"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#212121" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label x:Name="ResultMessageLabel"
                               FontSize="13"
                               TextColor="#9E9E9E"
                               HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Bottom action bar ── -->
        <VerticalStackLayout Grid.Row="2"
                             BackgroundColor="White"
                             Padding="16,14,16,20"
                             Spacing="10">

            <!-- Loading state -->
            <VerticalStackLayout x:Name="LoadingPanel"
                                 IsVisible="False"
                                 HorizontalOptions="Center"
                                 Spacing="6">
                <ActivityIndicator IsRunning="True"
                                   Color="#1565C0"
                                   HorizontalOptions="Center" />
                <Label Text="Analyzing face…"
                       FontSize="13"
                       TextColor="#757575"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Photo source buttons -->
            <VerticalStackLayout x:Name="PhotoButtonsRow" Spacing="10">
                <!-- Desktop: file picker -->
                <Button x:Name="SelectFileButton"
                        Text="📁  Select File"
                        Clicked="OnSelectFileClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#424242"
                        CornerRadius="10"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />
                <!-- Mobile: camera -->
                <Button x:Name="TakePhotoButton"
                        Text="📷  Take Photo"
                        Clicked="OnTakePhotoClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#424242"
                        CornerRadius="10"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />
            </VerticalStackLayout>

            <!-- Recognize button -->
            <Button x:Name="RecognizeButton"
                    Text="Identify Face"
                    Clicked="OnRecognizeClicked"
                    IsEnabled="False"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="52" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>
