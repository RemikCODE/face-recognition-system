# Zawartość folderu dataset (duże pliki ze zdjęciami twarzy – nie commitujemy)
# Sam folder dataset/ jest w repozytorium (z .gitkeep)
dataset/*
!dataset/.gitkeep

# Cache DeepFace (tworzony automatycznie przez DeepFace.find w folderze dataset/)
*.pkl

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.env

# Tymczasowe pliki
*.tmp
*.log

# Generowany przez setup-windows.bat
run-windows.bat
